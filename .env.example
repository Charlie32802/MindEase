# ============================================================
# MindEase — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:          copy .env.example .env
#   2. Fill in the real values below (ask the team lead for keys)
#   3. NEVER commit your .env file to GitHub
# ============================================================

# --- AI Companion (Groq) ---
GROQ_API_KEY=your_groq_api_key_here

# --- News APIs ---
NEWS_API_KEY=your_newsapi_key_here
RSS2JSON_API_KEY=your_rss2json_key_here
GNEWS_API_KEY=your_gnews_key_here

# --- Video Call (Daily.co & Agora) ---
DAILY_API_KEY=your_daily_api_key_here
AGORA_APP_ID=your_agora_app_id_here

# --- Django Core ---
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=False

# --- Email (Gmail SMTP) ---
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# --- MySQL Database ---
DB_NAME=mindease_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Production Domain (set when deploying) ---
PRODUCTION_DOMAIN=your-production-domain.com
